#!/usr/bin/env bash
set -euo pipefail

umask 077
export LC_ALL=C

readonly BUILDER_IMAGE="rust:1.96.0-bookworm@sha256:5e2214abe154fe26e39f64488952e5c991eeed1d6d6da7cc8381ae83927f0cfc"
REPOSITORY_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
readonly REPOSITORY_ROOT
readonly DOCKER_BIN="${PGGOMTM_DOCKER_BIN:-docker}"
readonly CONTAINER_NAME="${PGGOMTM_NATIVE_CONTAINER:-pggomtm-native-${GITHUB_RUN_ID:-local}-${GITHUB_RUN_ATTEMPT:-0}}"
readonly PGRX_PG_CONFIG_PATH="/opt/postgresql-18.4/bin/pg_config"

fail() {
  printf 'native-container: %s\n' "$1" >&2
  exit 2
}

require_github_actions() {
  test "${GITHUB_ACTIONS:-}" = "true" || \
    fail "recomputation is restricted to GitHub Actions; run the Native CI workflow"
}

require_docker() {
  command -v "${DOCKER_BIN}" >/dev/null || fail "Docker is unavailable"
}

create_container() {
  require_docker
  if "${DOCKER_BIN}" inspect "${CONTAINER_NAME}" >/dev/null 2>&1; then
    fail "native toolchain container already exists: ${CONTAINER_NAME}"
  fi

  "${DOCKER_BIN}" pull "${BUILDER_IMAGE}" >/dev/null
  "${DOCKER_BIN}" create \
    --name "${CONTAINER_NAME}" \
    --platform linux/amd64 \
    --mount "type=bind,src=${REPOSITORY_ROOT},dst=/workspace" \
    --workdir /workspace \
    --env "GITHUB_ACTIONS=true" \
    --env "PGRX_PG_CONFIG_PATH=${PGRX_PG_CONFIG_PATH}" \
    --entrypoint sleep \
    "${BUILDER_IMAGE}" \
    infinity >/dev/null
  "${DOCKER_BIN}" start "${CONTAINER_NAME}" >/dev/null
}

run_native_test() {
  test "$#" -ge 1 || fail "exec requires a native-test command"
  require_docker
  "${DOCKER_BIN}" exec \
    --env "GITHUB_ACTIONS=true" \
    --env "PGRX_PG_CONFIG_PATH=${PGRX_PG_CONFIG_PATH}" \
    "${CONTAINER_NAME}" \
    /workspace/scripts/native-test \
    "$@"
}

destroy_container() {
  require_docker
  "${DOCKER_BIN}" rm --force "${CONTAINER_NAME}" >/dev/null 2>&1 || true
}

usage() {
  printf '%s\n' \
    'usage: scripts/native-container <command> [arguments]' \
    '' \
    'commands:' \
    '  create            create the pinned native toolchain container' \
    '  prepare           install and verify native build dependencies' \
    '  exec COMMAND ...  run one scripts/native-test command' \
    '  destroy           remove the native toolchain container'
}

case "${1:-}" in
  help|--help|-h)
    usage
    ;;
  create)
    require_github_actions
    create_container
    ;;
  prepare)
    require_github_actions
    run_native_test prepare
    ;;
  exec)
    require_github_actions
    shift
    run_native_test "$@"
    ;;
  destroy)
    destroy_container
    ;;
  *)
    usage >&2
    exit 2
    ;;
esac
