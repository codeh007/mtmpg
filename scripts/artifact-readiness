#!/usr/bin/env bash
set -euo pipefail

umask 077
export LC_ALL=C

readonly BUILD_IDENTITY_SCHEMA="pggomtm-build-identity/v1"
readonly BUILD_MANIFEST_SCHEMA="pggomtm-build-manifest/v1"
readonly BUILD_IDENTITY_FILE="pggomtm_build_identity.json"
readonly MODULE_LOGICAL_PATH="/usr/lib/postgresql/18/lib/pggomtm.so"
readonly LICENSE_LOGICAL_PATH="/usr/share/doc/pggomtm/LICENSE"
readonly MANIFEST_LOGICAL_PATH="/usr/share/doc/pggomtm/build-manifest.json"
readonly LICENSE_SHA256="d00a4102edfa58b1d8c98e04635821b84ef7e86baad33d8888f61613322717a3"

readonly READELF_BIN="${PGGOMTM_READELF_BIN:-readelf}"
readonly NM_BIN="${PGGOMTM_NM_BIN:-nm}"
readonly PG_CONFIG_BIN="${PGGOMTM_PG_CONFIG_BIN:-pg_config}"
readonly UNAME_BIN="${PGGOMTM_UNAME_BIN:-uname}"
readonly DPKG_BIN="${PGGOMTM_DPKG_BIN:-dpkg}"
readonly GETCONF_BIN="${PGGOMTM_GETCONF_BIN:-getconf}"
readonly LDD_BIN="${PGGOMTM_LDD_BIN:-ldd}"

SESSION_TEMP_ROOT="$(mktemp --directory)"
readonly SESSION_TEMP_ROOT
trap 'rm -rf "${SESSION_TEMP_ROOT}"' EXIT

fail() {
  printf 'artifact-readiness: %s\n' "$1" >&2
  exit 2
}

require_tool() {
  command -v "$1" >/dev/null || fail "required tool is unavailable"
}

regular_file() {
  local path="$1"
  local label="$2"

  test -f "${path}" || fail "${label} is not a regular file"
  test ! -L "${path}" || fail "${label} must not be a symbolic link"
  test -r "${path}" || fail "${label} is not readable"
}

sha256_file() {
  sha256sum -- "$1" | cut -d' ' -f1
}

validate_build_identity() {
  local identity="$1"

  jq --exit-status \
    --arg schema "${BUILD_IDENTITY_SCHEMA}" '
      def exact_keys($expected):
        (keys | sort) == ($expected | sort);
      def sha256:
        type == "string" and test("^[0-9a-f]{64}$");

      type == "object"
      and exact_keys([
        "dependencies",
        "features",
        "module_version",
        "platform",
        "postgresql",
        "rust",
        "schema"
      ])
      and .schema == $schema
      and (.module_version | type == "string"
        and test("^[0-9]+[.][0-9]+[.][0-9]+([-+][0-9A-Za-z.-]+)?$"))
      and .features == ["pg18"]
      and (.rust | type == "object"
        and exact_keys(["target", "version"])
        and .version == "1.97.1"
        and .target == "x86_64-unknown-linux-gnu")
      and (.dependencies | type == "object"
        and exact_keys(["jose_implementation", "jose_version", "pgrx"])
        and .pgrx == "0.19.1"
        and .jose_implementation == "jaws"
        and .jose_version == "1.0.4")
      and (.postgresql | type == "object"
        and exact_keys([
          "oauth_bindings_sha256",
          "oauth_header_sha256",
          "pg_version_num",
          "runtime_base",
          "runtime_base_sha256",
          "source_sha256",
          "source_version"
        ])
        and .source_version == "18.4"
        and .pg_version_num == 180004
        and (.source_sha256 | sha256)
        and (.oauth_header_sha256 | sha256)
        and (.oauth_bindings_sha256 | sha256)
        and .runtime_base == "postgres:18.4-bookworm"
        and (.runtime_base_sha256 | sha256))
      and (.platform | type == "object"
        and exact_keys(["arch", "libc", "os"])
        and .os == "linux"
        and .arch == "amd64"
        and .libc == "glibc")
    ' "${identity}" >/dev/null || fail "production build identity is invalid"
}

select_build_identity() {
  local identity_root="$1"
  local output_variable="$2"

  local canonical_root
  canonical_root="$(realpath -- "${identity_root}")" || \
    fail "build identity root cannot be resolved"
  test -d "${canonical_root}" || fail "build identity root is not a directory"

  local inventory="${SESSION_TEMP_ROOT}/build-identities"
  find "${canonical_root}" -type f -name "${BUILD_IDENTITY_FILE}" -print0 \
    >"${inventory}" || fail "build identities could not be enumerated"

  local -a production_identities=()
  local candidate
  while IFS= read -r -d '' candidate; do
    jq --exit-status '.schema == "pggomtm-build-identity/v1"' \
      "${candidate}" >/dev/null || fail "a discovered build identity is invalid"
    if jq --exit-status '.features == ["pg18"]' "${candidate}" >/dev/null; then
      production_identities+=("${candidate}")
    fi
  done <"${inventory}"

  test "${#production_identities[@]}" -eq 1 || \
    fail "exactly one production build identity is required"
  validate_build_identity "${production_identities[0]}"
  printf -v "${output_variable}" '%s' "${production_identities[0]}"
}

validate_license() {
  local license_file="$1"

  regular_file "${license_file}" "MIT license"
  test "$(sha256_file "${license_file}")" = "${LICENSE_SHA256}" || \
    fail "MIT license checksum does not match the repository authority"
}

create_build_manifest() {
  test "$#" -eq 4 || \
    fail "create-build-manifest requires identity root, module, license, and output"

  local identity_root="$1"
  local module_file="$2"
  local license_file="$3"
  local output_file="$4"

  regular_file "${module_file}" "production module"
  validate_license "${license_file}"
  require_tool jq
  require_tool sha256sum

  local identity=""
  select_build_identity "${identity_root}" identity

  local output_parent
  output_parent="$(dirname -- "${output_file}")"
  output_parent="$(realpath -- "${output_parent}")" || \
    fail "build manifest output directory cannot be resolved"
  test -d "${output_parent}" || fail "build manifest output directory is unavailable"

  local module_sha256
  module_sha256="$(sha256_file "${module_file}")"
  local output_temp="${SESSION_TEMP_ROOT}/build-manifest.json"
  jq --sort-keys --compact-output \
    --arg schema "${BUILD_MANIFEST_SCHEMA}" \
    --arg module_path "${MODULE_LOGICAL_PATH}" \
    --arg module_sha256 "${module_sha256}" \
    --arg license_path "${LICENSE_LOGICAL_PATH}" \
    --arg license_sha256 "${LICENSE_SHA256}" '
      {
        schema: $schema,
        module: {
          name: "pggomtm",
          version: .module_version,
          features: .features,
          path: $module_path,
          sha256: $module_sha256
        },
        rust: .rust,
        dependencies: .dependencies,
        postgresql: .postgresql,
        platform: .platform,
        license: {
          spdx: "MIT",
          path: $license_path,
          sha256: $license_sha256
        }
      }
    ' "${identity}" >"${output_temp}" || fail "build manifest could not be generated"

  install -m 0644 -- "${output_temp}" "${output_file}"
  verify_build_manifest \
    "${output_file}" \
    "${module_file}" \
    "${license_file}" \
    "${identity_root}"
}

validate_manifest_schema() {
  local manifest="$1"

  jq --exit-status \
    --arg schema "${BUILD_MANIFEST_SCHEMA}" \
    --arg module_path "${MODULE_LOGICAL_PATH}" \
    --arg license_path "${LICENSE_LOGICAL_PATH}" \
    --arg license_sha256 "${LICENSE_SHA256}" '
      def exact_keys($expected):
        (keys | sort) == ($expected | sort);
      def sha256:
        type == "string" and test("^[0-9a-f]{64}$");

      type == "object"
      and exact_keys([
        "dependencies",
        "license",
        "module",
        "platform",
        "postgresql",
        "rust",
        "schema"
      ])
      and .schema == $schema
      and (.module | type == "object"
        and exact_keys(["features", "name", "path", "sha256", "version"])
        and .name == "pggomtm"
        and (.version | type == "string"
          and test("^[0-9]+[.][0-9]+[.][0-9]+([-+][0-9A-Za-z.-]+)?$"))
        and .features == ["pg18"]
        and .path == $module_path
        and (.sha256 | sha256))
      and (.rust | type == "object"
        and exact_keys(["target", "version"])
        and .version == "1.97.1"
        and .target == "x86_64-unknown-linux-gnu")
      and (.dependencies | type == "object"
        and exact_keys(["jose_implementation", "jose_version", "pgrx"])
        and .pgrx == "0.19.1"
        and .jose_implementation == "jaws"
        and .jose_version == "1.0.4")
      and (.postgresql | type == "object"
        and exact_keys([
          "oauth_bindings_sha256",
          "oauth_header_sha256",
          "pg_version_num",
          "runtime_base",
          "runtime_base_sha256",
          "source_sha256",
          "source_version"
        ])
        and .source_version == "18.4"
        and .pg_version_num == 180004
        and (.source_sha256 | sha256)
        and (.oauth_header_sha256 | sha256)
        and (.oauth_bindings_sha256 | sha256)
        and .runtime_base == "postgres:18.4-bookworm"
        and (.runtime_base_sha256 | sha256))
      and (.platform | type == "object"
        and exact_keys(["arch", "libc", "os"])
        and .os == "linux"
        and .arch == "amd64"
        and .libc == "glibc")
      and (.license | type == "object"
        and exact_keys(["path", "sha256", "spdx"])
        and .spdx == "MIT"
        and .path == $license_path
        and .sha256 == $license_sha256)
      and ([paths(scalars) as $path
        | select(
            ($path[-1] | type) == "string"
            and ($path[-1] | ascii_downcase
              | test("(oci|image).*digest|digest.*(oci|image)"))
          )] | length == 0)
      and ([.. | strings
        | select(
            test("^sha256:[0-9a-f]{64}$")
            or test("(?i)(<[^>]*digest[^>]*>|placeholder|(^|[^a-z])tbd([^a-z]|$))")
          )] | length == 0)
    ' "${manifest}" >/dev/null || fail "build manifest schema or public metadata is invalid"
}

verify_build_manifest() {
  test "$#" -eq 4 || \
    fail "verify-build-manifest requires manifest, module, license, and identity root"

  local manifest="$1"
  local module_file="$2"
  local license_file="$3"
  local identity_root="$4"

  regular_file "${manifest}" "build manifest"
  regular_file "${module_file}" "production module"
  validate_license "${license_file}"
  require_tool jq
  require_tool sha256sum

  validate_manifest_schema "${manifest}"

  local identity=""
  select_build_identity "${identity_root}" identity
  jq --exit-status \
    --slurpfile identity "${identity}" '
      ($identity | length) == 1
      and .module.version == $identity[0].module_version
      and .module.features == $identity[0].features
      and .rust == $identity[0].rust
      and .dependencies == $identity[0].dependencies
      and .postgresql == $identity[0].postgresql
      and .platform == $identity[0].platform
    ' "${manifest}" >/dev/null || \
    fail "build manifest does not match the production build identity"

  local canonical="${SESSION_TEMP_ROOT}/canonical-build-manifest.json"
  jq --sort-keys --compact-output . "${manifest}" >"${canonical}" || \
    fail "build manifest is not valid JSON"
  cmp --silent -- "${manifest}" "${canonical}" || \
    fail "build manifest bytes are not canonical JSON"

  local module_sha256
  module_sha256="$(sha256_file "${module_file}")"
  test "$(jq --raw-output '.module.sha256' "${manifest}")" = "${module_sha256}" || \
    fail "build manifest module checksum does not match the artifact"
  test "$(jq --raw-output '.license.sha256' "${manifest}")" = "${LICENSE_SHA256}" || \
    fail "build manifest license checksum does not match the repository authority"
}

excluded_snapshot_path() {
  local path="$1"
  local output_file="$2"

  if [[ "${path}" == "${SESSION_TEMP_ROOT}" || "${path}" == "${SESSION_TEMP_ROOT}/"* ]]; then
    return 0
  fi
  if [[ "${path}" == "${output_file}" ]]; then
    return 0
  fi
  case "${path}" in
    /dev|/dev/*|/proc|/proc/*|/sys|/sys/*|\
    /etc/hostname|/etc/hosts|/etc/resolv.conf|\
    /tmp/pggomtm-artifact-readiness|\
    /tmp/pggomtm-artifact-base.tsv|\
    /tmp/pggomtm-artifact-candidate.tsv)
      return 0
      ;;
  esac
  return 1
}

snapshot_filesystem() {
  test "$#" -eq 2 || fail "snapshot-filesystem requires root and output"

  local root="$1"
  local output_file="$2"
  root="$(realpath -- "${root}")" || fail "filesystem root cannot be resolved"
  test -d "${root}" || fail "filesystem root is not a directory"

  local output_parent
  output_parent="$(realpath -- "$(dirname -- "${output_file}")")" || \
    fail "filesystem inventory output directory cannot be resolved"
  test -d "${output_parent}" || fail "filesystem inventory output directory is unavailable"
  local canonical_output
  canonical_output="${output_parent}/$(basename -- "${output_file}")"
  local unsorted="${SESSION_TEMP_ROOT}/filesystem-unsorted.tsv"
  : >"${unsorted}"

  require_tool find
  require_tool xargs
  local hash_records="${SESSION_TEMP_ROOT}/filesystem-hashes"
  find "${root}" -xdev -type f -print0 \
    | xargs --null --no-run-if-empty sha256sum --zero -- \
    >"${hash_records}" || fail "filesystem file checksums could not be generated"

  local -A file_hashes=()
  local hash_record
  while IFS= read -r -d '' hash_record; do
    test "${#hash_record}" -ge 67 || fail "filesystem checksum record is invalid"
    local hash="${hash_record:0:64}"
    local separator="${hash_record:64:2}"
    local hashed_path="${hash_record:66}"
    [[ "${hash}" =~ ^[0-9a-f]+$ ]] && test "${#hash}" -eq 64 || \
      fail "filesystem checksum is invalid"
    [[ "${separator}" == "  " || "${separator}" == " *" ]] || \
      fail "filesystem checksum separator is invalid"
    test -n "${hashed_path}" || fail "filesystem checksum path is empty"
    file_hashes["${hashed_path}"]="${hash}"
  done <"${hash_records}"

  local path
  local file_type
  local mode
  local owner
  local group
  local link_target
  while IFS= read -r -d '' path \
    && IFS= read -r -d '' file_type \
    && IFS= read -r -d '' mode \
    && IFS= read -r -d '' owner \
    && IFS= read -r -d '' group \
    && IFS= read -r -d '' link_target; do
    excluded_snapshot_path "${path}" "${canonical_output}" && continue

    local logical_path
    if [[ "${root}" == "/" ]]; then
      logical_path="${path}"
    else
      logical_path="/${path#"${root}/"}"
    fi
    if [[ "${logical_path}" == *$'\n'* || "${logical_path}" == *$'\t'* ]]; then
      fail "filesystem path contains unsupported control characters"
    fi

    local detail
    case "${file_type}" in
      l)
        detail="${link_target}"
        test -n "${detail}" || fail "symbolic link target cannot be read"
        ;;
      d)
        detail="-"
        ;;
      f)
        detail="${file_hashes["${path}"]:-}"
        test -n "${detail}" || fail "filesystem file checksum is unavailable"
        ;;
      *)
        fail "filesystem contains an unsupported file type"
        ;;
    esac
    if [[ "${file_type}" == "l" ]]; then
      if [[ "${detail}" == *$'\n'* || "${detail}" == *$'\t'* ]]; then
        fail "symbolic link target contains unsupported control characters"
      fi
    fi

    printf '%s\t%s\t%s\t%s\t%s\t%s\n' \
      "${logical_path}" \
      "${file_type}" \
      "${mode}" \
      "${owner}" \
      "${group}" \
      "${detail}" \
      >>"${unsorted}"
  done < <(
    find "${root}" -xdev -mindepth 1 \
      -printf '%p\0%y\0%m\0%U\0%G\0%l\0'
  )

  sort --unique --output="${canonical_output}" "${unsorted}"
  chmod 0644 "${canonical_output}"
}

validate_inventory() {
  local inventory="$1"
  local label="$2"

  regular_file "${inventory}" "${label}"
  sort --check=quiet --unique "${inventory}" || \
    fail "${label} must be uniquely sorted"
  awk -F '\t' '
    NF != 6 { exit 1 }
    $1 !~ /^\// || $1 ~ /[\r\n]/ { exit 1 }
    $2 !~ /^[dfl]$/ { exit 1 }
    $3 !~ /^[0-7][0-7][0-7][0-7]?$/ { exit 1 }
    $4 !~ /^[0-9]+$/ || $5 !~ /^[0-9]+$/ { exit 1 }
    $2 == "f" && (length($6) != 64 || $6 !~ /^[0-9a-f]+$/) { exit 1 }
    $2 == "d" && $6 != "-" { exit 1 }
    $2 == "l" && $6 == "" { exit 1 }
  ' "${inventory}" || fail "${label} has an invalid record"
}

verify_filesystem() {
  test "$#" -eq 2 || \
    fail "verify-filesystem requires base and candidate inventories"

  local base_inventory="$1"
  local candidate_inventory="$2"
  validate_inventory "${base_inventory}" "official base filesystem inventory"
  validate_inventory "${candidate_inventory}" "candidate filesystem inventory"

  local removed="${SESSION_TEMP_ROOT}/filesystem-removed.tsv"
  local added="${SESSION_TEMP_ROOT}/filesystem-added.tsv"
  comm -23 "${base_inventory}" "${candidate_inventory}" >"${removed}"
  comm -13 "${base_inventory}" "${candidate_inventory}" >"${added}"
  test ! -s "${removed}" || fail "candidate changed or removed official base filesystem entries"
  test "$(wc -l <"${added}")" -eq 4 || \
    fail "candidate filesystem additions do not match the four-entry allowlist"

  awk -F '\t' '
    BEGIN {
      module = "/usr/lib/postgresql/18/lib/pggomtm.so"
      doc = "/usr/share/doc/pggomtm"
      license = "/usr/share/doc/pggomtm/LICENSE"
      manifest = "/usr/share/doc/pggomtm/build-manifest.json"
    }
    $1 == module {
      valid = ($2 == "f" && $3 == "644" && $4 == "0" && $5 == "0" \
        && length($6) == 64 && $6 ~ /^[0-9a-f]+$/)
      seen_module++
      if (!valid) exit 1
      next
    }
    $1 == doc {
      valid = $2 == "d" && $3 == "755" && $4 == "0" && $5 == "0" && $6 == "-"
      seen_doc++
      if (!valid) exit 1
      next
    }
    $1 == license || $1 == manifest {
      valid = ($2 == "f" && $3 == "644" && $4 == "0" && $5 == "0" \
        && length($6) == 64 && $6 ~ /^[0-9a-f]+$/)
      if ($1 == license) seen_license++
      if ($1 == manifest) seen_manifest++
      if (!valid) exit 1
      next
    }
    { exit 1 }
    END {
      if (seen_module != 1 || seen_doc != 1 || seen_license != 1 || seen_manifest != 1) {
        exit 1
      }
    }
  ' "${added}" || fail "candidate filesystem contains an unapproved addition"
}

verify_elf() {
  test "$#" -eq 1 || fail "verify-elf requires exactly one module"

  local module_file="$1"
  regular_file "${module_file}" "production ELF module"
  require_tool "${READELF_BIN}"
  require_tool "${NM_BIN}"

  local elf_header="${SESSION_TEMP_ROOT}/elf-header"
  "${READELF_BIN}" --file-header --wide "${module_file}" >"${elf_header}" || \
    fail "production module is not a readable ELF file"
  grep --quiet --extended-regexp '^[[:space:]]*Class:[[:space:]]+ELF64$' \
    "${elf_header}" || fail "production module must be ELF64"
  grep --quiet --extended-regexp \
    '^[[:space:]]*Data:[[:space:]]+2.s complement, little endian$' \
    "${elf_header}" || fail "production module must use little-endian encoding"
  grep --quiet --extended-regexp \
    '^[[:space:]]*Type:[[:space:]]+DYN \(Shared object file\)$' \
    "${elf_header}" || fail "production module must be a shared object"
  grep --quiet --extended-regexp \
    '^[[:space:]]*Machine:[[:space:]]+Advanced Micro Devices X86-64$' \
    "${elf_header}" || fail "production module must target x86-64"

  local dependencies="${SESSION_TEMP_ROOT}/elf-dependencies"
  local expected_dependencies="${SESSION_TEMP_ROOT}/expected-elf-dependencies"
  "${READELF_BIN}" --dynamic --wide "${module_file}" \
    | sed -n 's/^.*(NEEDED).*Shared library: \[\([^]]*\)\].*$/\1/p' \
    | sort --unique >"${dependencies}" || fail "ELF dependencies could not be read"
  printf '%s\n' \
    'ld-linux-x86-64.so.2' \
    'libc.so.6' \
    'libgcc_s.so.1' \
    | sort >"${expected_dependencies}"
  cmp --silent -- "${dependencies}" "${expected_dependencies}" || \
    fail "production module dynamic dependency set is not approved"

  local exports="${SESSION_TEMP_ROOT}/elf-exports"
  local expected_exports="${SESSION_TEMP_ROOT}/expected-elf-exports"
  "${NM_BIN}" --dynamic --defined-only --extern-only --format=posix "${module_file}" \
    | awk '{ sub(/@.*/, "", $1); print $1 }' \
    | sort --unique >"${exports}" || fail "ELF exports could not be read"
  printf '%s\n' \
    'Pg_magic_func' \
    '_PG_oauth_validator_module_init' \
    | sort >"${expected_exports}"
  cmp --silent -- "${exports}" "${expected_exports}" || \
    fail "production module export set is not approved"
}

verify_dockerfile() {
  test "$#" -eq 1 || fail "verify-dockerfile requires exactly one Dockerfile"

  local dockerfile="$1"
  regular_file "${dockerfile}" "Dockerfile"

  local final_stage="${SESSION_TEMP_ROOT}/dockerfile-final-stage"
  awk '
    function trim(value) {
      sub(/^[ \t]+/, "", value)
      sub(/[ \t\r]+$/, "", value)
      return value
    }
    function finish_instruction() {
      instruction = trim(instruction)
      gsub(/[ \t]+/, " ", instruction)
      split(instruction, fields, /[ \t]+/)
      if (toupper(fields[1]) == "FROM") {
        instruction_count = 0
      }
      instructions[++instruction_count] = instruction
      instruction = ""
    }
    {
      current = trim($0)
      if (current == "" || substr(current, 1, 1) == "#") {
        next
      }
      continued = sub(/\\[ \t]*$/, "", current)
      if (instruction == "") {
        instruction = current
      } else {
        instruction = instruction " " current
      }
      if (!continued) {
        finish_instruction()
      }
    }
    END {
      if (instruction != "") {
        exit 1
      }
      for (entry = 1; entry <= instruction_count; entry++) {
        print instructions[entry]
      }
    }
  ' "${dockerfile}" >"${final_stage}" || \
    fail "final Docker stage could not be parsed"

  local expected="${SESSION_TEMP_ROOT}/expected-dockerfile-final-stage"
  printf '%s\n' \
    'FROM candidate-content' \
    'RUN --mount=type=bind,from=candidate-artifact-gate,source=/tmp/pggomtm-candidate-artifact-gate-passed,target=/tmp/pggomtm-candidate-artifact-gate-passed,ro test -f /tmp/pggomtm-candidate-artifact-gate-passed' \
    'ENTRYPOINT ["docker-entrypoint.sh"]' \
    'CMD ["postgres"]' \
    >"${expected}"
  cmp --silent -- "${final_stage}" "${expected}" || \
    fail "final Docker stage contains an unapproved instruction or configuration"
}

root_path() {
  local root="$1"
  local logical_path="$2"

  if [[ "${root}" == "/" ]]; then
    printf '%s\n' "${logical_path}"
  else
    printf '%s%s\n' "${root}" "${logical_path}"
  fi
}

verify_mode_owner() {
  local path="$1"
  local expected_mode="$2"

  test "$(stat --format='%a' -- "${path}")" = "${expected_mode}" || \
    fail "runtime artifact mode is not approved"
  test "$(stat --format='%u:%g' -- "${path}")" = "0:0" || \
    fail "runtime artifact owner is not root:root"
}

verify_runtime() {
  test "$#" -eq 1 || fail "verify-runtime requires exactly one filesystem root"

  local root="$1"
  root="$(realpath -- "${root}")" || fail "runtime filesystem root cannot be resolved"
  test "${root}" = "/" || fail "verify-runtime must execute inside the candidate root"

  local module_file
  local license_file
  local manifest_file
  local doc_directory
  local entrypoint_file
  module_file="$(root_path "${root}" "${MODULE_LOGICAL_PATH}")"
  license_file="$(root_path "${root}" "${LICENSE_LOGICAL_PATH}")"
  manifest_file="$(root_path "${root}" "${MANIFEST_LOGICAL_PATH}")"
  doc_directory="$(root_path "${root}" "/usr/share/doc/pggomtm")"
  entrypoint_file="$(root_path "${root}" "/usr/local/bin/docker-entrypoint.sh")"

  regular_file "${module_file}" "runtime production module"
  regular_file "${license_file}" "runtime MIT license"
  regular_file "${manifest_file}" "runtime build manifest"
  test -d "${doc_directory}" || fail "runtime documentation directory is unavailable"
  test -f "${entrypoint_file}" && test -x "${entrypoint_file}" || \
    fail "official PostgreSQL entrypoint is unavailable"

  require_tool "${PG_CONFIG_BIN}"
  require_tool "${UNAME_BIN}"
  require_tool "${DPKG_BIN}"
  require_tool "${GETCONF_BIN}"
  require_tool "${LDD_BIN}"

  local package_library_directory
  package_library_directory="$("${PG_CONFIG_BIN}" --pkglibdir)" || \
    fail "pg_config package library directory could not be read"
  test "${package_library_directory}/pggomtm.so" = "${MODULE_LOGICAL_PATH}" || \
    fail "runtime module is not installed in pg_config --pkglibdir"
  test "$("${PG_CONFIG_BIN}" --version)" = \
    "PostgreSQL 18.4 (Debian 18.4-1.pgdg12+1)" || \
    fail "runtime PostgreSQL version is not the verified minor"
  test "$("${UNAME_BIN}" -m)" = "x86_64" || fail "runtime machine is not x86_64"
  test "$("${DPKG_BIN}" --print-architecture)" = "amd64" || \
    fail "runtime package architecture is not amd64"
  [[ "$("${GETCONF_BIN}" GNU_LIBC_VERSION)" == glibc\ * ]] || \
    fail "runtime libc is not glibc"

  local ldd_output="${SESSION_TEMP_ROOT}/runtime-ldd"
  "${LDD_BIN}" "${module_file}" >"${ldd_output}" 2>&1 || \
    fail "runtime linker could not resolve the production module"
  ! grep --quiet --fixed-strings 'not found' "${ldd_output}" || \
    fail "runtime module has an unresolved dynamic dependency"
  local dependency
  for dependency in ld-linux-x86-64.so.2 libc.so.6 libgcc_s.so.1; do
    grep --quiet --fixed-strings "${dependency}" "${ldd_output}" || \
      fail "runtime linker output omitted an approved dependency"
  done

  verify_mode_owner "${module_file}" "644"
  verify_mode_owner "${license_file}" "644"
  verify_mode_owner "${manifest_file}" "644"
  verify_mode_owner "${doc_directory}" "755"
}

main() {
  local command="${1:-}"
  case "${command}" in
    create-build-manifest)
      shift
      create_build_manifest "$@"
      ;;
    verify-build-manifest)
      shift
      verify_build_manifest "$@"
      ;;
    snapshot-filesystem)
      shift
      snapshot_filesystem "$@"
      ;;
    verify-filesystem)
      shift
      verify_filesystem "$@"
      ;;
    verify-elf)
      shift
      verify_elf "$@"
      ;;
    verify-dockerfile)
      shift
      verify_dockerfile "$@"
      ;;
    verify-runtime)
      shift
      verify_runtime "$@"
      ;;
    *)
      fail "expected command: create-build-manifest, verify-build-manifest, snapshot-filesystem, verify-filesystem, verify-elf, verify-dockerfile, or verify-runtime"
      ;;
  esac
}

main "$@"
