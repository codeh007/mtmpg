#!/usr/bin/env bash
set -euo pipefail

umask 077
export LC_ALL=C

REPOSITORY_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
readonly REPOSITORY_ROOT
readonly PG_HEADER_DIGEST="be015ae68deef28a906c8739bc653ca90a4c6966c10f0efd3bd926efb4958bcf"
readonly POSTGRESQL_SOURCE_SHA256="81a81ec695fb0c7901407defaa1d2f7973617154cf27ba74e3a7ab8e64436094"
readonly CARGO_DENY_ARCHIVE_SHA256="9f12ed4c49936e09b48bf862b595cde2fe64fcbd9d74dfacac6131ca824c8d5f"
readonly SHELLCHECK_ARCHIVE_SHA256="8c3be12b05d5c177a04c29e3c78ce89ac86f1595681cab149b65b97c4e227198"
readonly ARTIFACT_READINESS_BIN="${PGGOMTM_ARTIFACT_READINESS_BIN:-${REPOSITORY_ROOT}/scripts/artifact-readiness}"
readonly SHELLCHECK_BIN="${PGGOMTM_SHELLCHECK_BIN:-shellcheck}"
readonly GITLEAKS_BIN="${PGGOMTM_GITLEAKS_BIN:-/usr/local/bin/gitleaks}"
readonly ARTIFACT_GATE_TEST="${PGGOMTM_ARTIFACT_GATE_TEST:-${REPOSITORY_ROOT}/tests/artifact_readiness_gate.sh}"
readonly DOCKERFILE_GATE_TEST="${PGGOMTM_DOCKERFILE_GATE_TEST:-${REPOSITORY_ROOT}/tests/dockerfile_responsibility_gate.sh}"
readonly IMAGE_GATE_TEST="${PGGOMTM_IMAGE_GATE_TEST:-${REPOSITORY_ROOT}/tests/image_readiness_entrypoint.sh}"
readonly PUBLIC_GATE_TEST="${PGGOMTM_PUBLIC_GATE_TEST:-${REPOSITORY_ROOT}/tests/public_readiness_gate.sh}"
readonly PREPARED_MARKER="${PGGOMTM_NATIVE_PREPARED_MARKER:-/opt/pggomtm-native-prepared-v1}"
SESSION_TEMP_ROOT=""

cleanup() {
  if test -n "${SESSION_TEMP_ROOT}"; then
    rm -rf -- "${SESSION_TEMP_ROOT}"
  fi
}

trap cleanup EXIT

fail() {
  printf 'native-test: %s\n' "$1" >&2
  exit 2
}

require_github_actions() {
  test "${GITHUB_ACTIONS:-}" = "true" || \
    fail "recomputation is restricted to GitHub Actions; run the Native CI workflow"
}

require_pg_config() {
  test -n "${PGRX_PG_CONFIG_PATH:-}" || \
    fail "PGRX_PG_CONFIG_PATH must identify the prepared PostgreSQL 18.4 pg_config"
  test -x "${PGRX_PG_CONFIG_PATH}" || fail "PGRX_PG_CONFIG_PATH is not executable"
  test "$("${PGRX_PG_CONFIG_PATH}" --version)" = "PostgreSQL 18.4" || \
    fail "pg_config does not identify PostgreSQL 18.4"
}

verify_prepared_toolchain() {
  require_pg_config
  test "$(rustc --version)" = "rustc 1.97.1 (8bab26f4f 2026-07-14)" || \
    fail "Rust compiler does not match 1.97.1"
  test "$(cargo --version)" = "cargo 1.97.1 (c980f4866 2026-06-30)" || \
    fail "Cargo does not match 1.97.1"
  test "$(cargo deny --version)" = "cargo-deny 0.20.2" || \
    fail "cargo-deny does not match 0.20.2"
  "${SHELLCHECK_BIN}" --version \
    | grep --quiet --fixed-strings 'version: 0.11.0' || \
    fail "ShellCheck does not match 0.11.0"
  test "$("${GITLEAKS_BIN}" version)" = "8.30.1" || \
    fail "Gitleaks does not match 8.30.1"

  local include_dir
  include_dir="$("${PGRX_PG_CONFIG_PATH}" --includedir-server)"
  printf '%s  %s\n' "${PG_HEADER_DIGEST}" "${include_dir}/libpq/oauth.h" \
    | sha256sum --check --strict >/dev/null || \
    fail "PostgreSQL OAuth header does not match the approved source"
}

install_prepared_toolchain() {
  test "$(id -u)" -eq 0 || fail "prepare must run as root in the native container"
  SESSION_TEMP_ROOT="$(mktemp --directory)"
  local download_root="${SESSION_TEMP_ROOT}"

  rustup toolchain install 1.97.1 \
    --profile minimal \
    --component clippy,rustfmt \
    --target x86_64-unknown-linux-gnu
  rustup default 1.97.1

  apt-get update
  apt-get install --yes --no-install-recommends \
    bison \
    build-essential \
    bzip2 \
    ca-certificates \
    clang \
    curl \
    flex \
    git \
    jq \
    libclang-dev \
    libssl-dev \
    pkg-config \
    xz-utils \
    zlib1g-dev
  rm -rf /var/lib/apt/lists/*

  local postgresql_archive="${download_root}/postgresql-18.4.tar.bz2"
  curl --fail --location --proto '=https' --tlsv1.2 \
    --silent --show-error \
    --output "${postgresql_archive}" \
    https://ftp.postgresql.org/pub/source/v18.4/postgresql-18.4.tar.bz2
  printf '%s  %s\n' "${POSTGRESQL_SOURCE_SHA256}" "${postgresql_archive}" \
    | sha256sum --check --strict >/dev/null
  tar --extract --bzip2 --file "${postgresql_archive}" --directory "${download_root}"
  local postgresql_prefix
  postgresql_prefix="$(dirname "$(dirname "${PGRX_PG_CONFIG_PATH}")")"
  (
    cd "${download_root}/postgresql-18.4"
    ./configure \
      --prefix="${postgresql_prefix}" \
      --with-openssl \
      --without-icu \
      --without-readline
    local build_jobs
    build_jobs="$(nproc)"
    if test "${build_jobs}" -gt 4; then
      build_jobs=4
    fi
    make -j"${build_jobs}"
    make install
  )

  local cargo_deny_archive="${download_root}/cargo-deny.tar.gz"
  curl --fail --location --proto '=https' --tlsv1.2 \
    --silent --show-error \
    --output "${cargo_deny_archive}" \
    https://github.com/EmbarkStudios/cargo-deny/releases/download/0.20.2/cargo-deny-0.20.2-x86_64-unknown-linux-musl.tar.gz
  printf '%s  %s\n' "${CARGO_DENY_ARCHIVE_SHA256}" "${cargo_deny_archive}" \
    | sha256sum --check --strict >/dev/null
  tar --extract --gzip --file "${cargo_deny_archive}" --directory "${download_root}"
  install -m 0755 \
    "${download_root}/cargo-deny-0.20.2-x86_64-unknown-linux-musl/cargo-deny" \
    /usr/local/bin/cargo-deny

  local shellcheck_archive="${download_root}/shellcheck.tar.xz"
  curl --fail --location --proto '=https' --tlsv1.2 \
    --silent --show-error \
    --output "${shellcheck_archive}" \
    https://github.com/koalaman/shellcheck/releases/download/v0.11.0/shellcheck-v0.11.0.linux.x86_64.tar.xz
  printf '%s  %s\n' "${SHELLCHECK_ARCHIVE_SHA256}" "${shellcheck_archive}" \
    | sha256sum --check --strict >/dev/null
  tar --extract --xz --file "${shellcheck_archive}" --directory "${download_root}"
  install -m 0755 \
    "${download_root}/shellcheck-v0.11.0/shellcheck" \
    /usr/local/bin/shellcheck

  "${REPOSITORY_ROOT}/scripts/public-readiness" install-gitleaks /usr/local/bin
  git config --system --add safe.directory "${REPOSITORY_ROOT}"
  install -m 0644 /dev/null "${PREPARED_MARKER}"
}

run_prepare() {
  if test ! -f "${PREPARED_MARKER}"; then
    install_prepared_toolchain
  fi
  verify_prepared_toolchain
}

run_cargo_tests() {
  require_pg_config
  cd "${REPOSITORY_ROOT}"

  cargo test --locked --no-default-features --features pg18,abi-gate
  cargo test --locked --no-default-features \
    --features pg18,abi-gate,pgx-oauth-gate \
    --test artifact_identity \
    --test pgx_oauth_gate
  cargo test --locked --no-default-features \
    --features pg18,abi-runtime-gate \
    --test artifact_identity
  cargo test --locked --no-default-features \
    --features pg18 \
    --test artifact_identity
}

run_dependencies() {
  require_pg_config
  cd "${REPOSITORY_ROOT}"

  cargo deny \
    --locked \
    --no-default-features \
    --features pg18 \
    check \
    --show-stats \
    advisories licenses bans sources
}

run_quality() {
  require_pg_config
  cd "${REPOSITORY_ROOT}"

  cargo fmt --check
  cargo clippy \
    --locked \
    --all-targets \
    --no-default-features \
    --features pg18,abi-gate \
    -- \
    -D warnings
  cargo clippy \
    --locked \
    --all-targets \
    --no-default-features \
    --features pg18,abi-gate,pgx-oauth-gate \
    -- \
    -D warnings
  cargo clippy \
    --locked \
    --lib \
    --no-default-features \
    --features pg18,abi-runtime-gate \
    -- \
    -D warnings
  cargo clippy \
    --locked \
    --lib \
    --no-default-features \
    --features pg18 \
    -- \
    -D warnings
}

run_abi() {
  require_pg_config
  cd "${REPOSITORY_ROOT}"

  local include_dir
  include_dir="$("${PGRX_PG_CONFIG_PATH}" --includedir-server)"
  test -d "${include_dir}" || fail "PostgreSQL server include directory is unavailable"
  test -f "${include_dir}/libpq/oauth.h" || fail "official OAuth header is unavailable"

  local -a cppflags=()
  read -r -a cppflags <<<"$("${PGRX_PG_CONFIG_PATH}" --cppflags)"
  SESSION_TEMP_ROOT="$(mktemp --directory)"
  local layout_probe="${SESSION_TEMP_ROOT}/pggomtm-oauth-layout-probe"

  cc -std=c11 -Wall -Wextra -Werror \
    "${cppflags[@]}" \
    -I"${include_dir}" \
    tests/oauth_layout_probe.c \
    -o "${layout_probe}"
  "${layout_probe}"
  printf '%s  %s\n' "${PG_HEADER_DIGEST}" "${include_dir}/libpq/oauth.h" \
    | sha256sum --check --strict >/dev/null

  cargo test --locked --no-default-features \
    --features pg18,abi-gate \
    --test oauth_build_provenance \
    -- \
    --ignored \
    --exact real_generator_rejects_unapproved_provenance_inputs
}

absolute_target_root() {
  local target_root="${CARGO_TARGET_DIR:-${REPOSITORY_ROOT}/target}"
  if [[ "${target_root}" != /* ]]; then
    target_root="${REPOSITORY_ROOT}/${target_root}"
  fi
  printf '%s\n' "${target_root}"
}

run_production_artifact() {
  require_pg_config
  test -x "${ARTIFACT_READINESS_BIN}" || fail "artifact-readiness gate is unavailable"
  cd "${REPOSITORY_ROOT}"

  local target_root
  local release_root
  local module_file
  local identity_root
  local source_revision
  target_root="$(absolute_target_root)"
  release_root="${target_root}/release"
  module_file="${release_root}/libpggomtm.so"
  identity_root="${release_root}/build"
  source_revision="${PGGOMTM_SOURCE_REVISION:-$(git rev-parse --verify HEAD)}"

  local artifact_dir="${PGGOMTM_NATIVE_ARTIFACT_DIR:-${target_root}/native-artifacts}"
  if [[ "${artifact_dir}" != /* ]]; then
    artifact_dir="${REPOSITORY_ROOT}/${artifact_dir}"
  fi
  install -d -m 0755 -- "${artifact_dir}"

  cargo test --locked --no-default-features \
    --features pg18 \
    --test artifact_identity
  cargo build --locked --release --lib --no-default-features --features pg18
  test -r "${module_file}" || fail "production module was not built"

  "${ARTIFACT_READINESS_BIN}" verify-elf "${module_file}"
  "${ARTIFACT_READINESS_BIN}" create-build-manifest \
    "${identity_root}" \
    "${module_file}" \
    "${REPOSITORY_ROOT}/LICENSE" \
    "${artifact_dir}/build-manifest.json" \
    "${source_revision}"
  "${ARTIFACT_READINESS_BIN}" verify-build-manifest \
    "${artifact_dir}/build-manifest.json" \
    "${module_file}" \
    "${REPOSITORY_ROOT}/LICENSE" \
    "${identity_root}" \
    "${source_revision}"

  SESSION_TEMP_ROOT="$(mktemp --directory)"
  local normal_dependencies="${SESSION_TEMP_ROOT}/normal-dependencies.txt"
  cargo tree --locked --no-default-features --features pg18 \
    --edges normal \
    --prefix none \
    >"${normal_dependencies}"
  PGGOMTM_NORMAL_DEPENDENCY_TREE="${normal_dependencies}" \
  PGGOMTM_PRODUCTION_SOURCE_ROOT="${REPOSITORY_ROOT}/src" \
  PGGOMTM_PRODUCTION_ARTIFACT="${module_file}" \
    cargo test --locked --no-default-features \
      --features pg18,abi-gate \
      --test production_capability_gate \
      -- \
      --ignored

  install -m 0644 -- "${module_file}" "${artifact_dir}/pggomtm.so"
  install -m 0644 -- "${REPOSITORY_ROOT}/LICENSE" "${artifact_dir}/LICENSE"
  "${ARTIFACT_READINESS_BIN}" verify-build-manifest \
    "${artifact_dir}/build-manifest.json" \
    "${artifact_dir}/pggomtm.so" \
    "${artifact_dir}/LICENSE" \
    "${identity_root}" \
    "${source_revision}"
}

run_policy() {
  command -v "${SHELLCHECK_BIN}" >/dev/null || fail "pinned ShellCheck binary is unavailable"
  command -v "${GITLEAKS_BIN}" >/dev/null || fail "pinned Gitleaks binary is unavailable"
  test -x "${ARTIFACT_GATE_TEST}" || fail "artifact gate fixture is unavailable"
  test -x "${DOCKERFILE_GATE_TEST}" || fail "Dockerfile responsibility fixture is unavailable"
  test -x "${IMAGE_GATE_TEST}" || fail "image-readiness fixture is unavailable"
  test -x "${PUBLIC_GATE_TEST}" || fail "public-readiness fixture is unavailable"
  cd "${REPOSITORY_ROOT}"

  "${SHELLCHECK_BIN}" \
    scripts/artifact-readiness \
    scripts/build-metadata \
    scripts/image-readiness \
    scripts/native-container \
    scripts/native-test \
    scripts/public-readiness \
    tests/artifact_readiness_gate.sh \
    tests/dockerfile_responsibility_gate.sh \
    tests/image_readiness_entrypoint.sh \
    tests/native_container_entrypoint.sh \
    tests/native_test_entrypoint.sh \
    tests/postgres_integration.sh \
    tests/postgres_integration_container.sh \
    tests/postgres_integration_entrypoint.sh \
    tests/public_readiness_gate.sh \
    tests/fixtures/public-readiness/fake-gh
  "${ARTIFACT_GATE_TEST}"
  "${DOCKERFILE_GATE_TEST}"
  "${IMAGE_GATE_TEST}"
  "${PUBLIC_GATE_TEST}" "${GITLEAKS_BIN}"
}

run_stage_integration() {
  require_pg_config
  cd "${REPOSITORY_ROOT}"

  local target_root
  target_root="$(absolute_target_root)"
  install -d -m 0755 -- "${target_root}"

  local integration_dir="${PGGOMTM_NATIVE_INTEGRATION_DIR:-${target_root}/native-integration}"
  if [[ "${integration_dir}" != /* ]]; then
    integration_dir="${REPOSITORY_ROOT}/${integration_dir}"
  fi
  integration_dir="$(realpath --canonicalize-missing -- "${integration_dir}")"
  case "${integration_dir}" in
    "${target_root}"/*) ;;
    *) fail "integration artifact directory must be inside the Cargo target directory" ;;
  esac

  SESSION_TEMP_ROOT="$(mktemp --directory "${target_root}/.native-integration.XXXXXX")"
  local staging_root="${SESSION_TEMP_ROOT}"
  local release_module="${target_root}/release/libpggomtm.so"

  cargo build --locked --release --no-default-features \
    --features pg18,abi-runtime-gate
  install -m 0644 -- "${release_module}" "${staging_root}/pggomtm_abi_gate.so"

  cargo build --locked --release --no-default-features \
    --features pg18,pgx-oauth-gate
  install -m 0644 -- "${release_module}" "${staging_root}/pggomtm_pgx_gate.so"

  cargo build --locked --release --no-default-features --features pg18
  install -m 0644 -- "${release_module}" "${staging_root}/pggomtm_config_gate.so"
  install -m 0644 -- "${release_module}" "${staging_root}/pggomtm_identity_gate.so"

  cargo build --locked --release --example pggomtm_oauth_smoke_fixture \
    --no-default-features \
    --features pg18,pgx-oauth-gate
  install -m 0755 -- \
    "${target_root}/release/examples/pggomtm_oauth_smoke_fixture" \
    "${staging_root}/pggomtm_oauth_smoke_fixture"

  local include_dir
  local client_include_dir
  local lib_dir
  include_dir="$("${PGRX_PG_CONFIG_PATH}" --includedir-server)"
  client_include_dir="$("${PGRX_PG_CONFIG_PATH}" --includedir)"
  lib_dir="$("${PGRX_PG_CONFIG_PATH}" --libdir)"
  local -a cppflags=()
  read -r -a cppflags <<<"$("${PGRX_PG_CONFIG_PATH}" --cppflags)"

  cc -std=c11 -Wall -Wextra -Werror -fPIC -shared \
    "${cppflags[@]}" \
    -I"${include_dir}" \
    tests/oauth_runtime_probe.c \
    -o "${staging_root}/pggomtm_abi_runtime_probe.so"
  cc -std=c11 -Wall -Wextra -Werror \
    -I"${client_include_dir}" \
    tests/oauth_smoke_client.c \
    -L"${lib_dir}" \
    -lpq \
    -o "${staging_root}/pggomtm_oauth_smoke_client"
  chmod 0644 "${staging_root}/pggomtm_abi_runtime_probe.so"
  chmod 0755 "${staging_root}/pggomtm_oauth_smoke_client"

  install -m 0644 -- \
    tests/oauth_runtime_probe.sql \
    tests/runtime_config_missing_probe.sql \
    tests/runtime_config_ready_probe.sql \
    tests/runtime_config_validate_probe.sql \
    "${staging_root}"
  install -d -m 0755 -- "${staging_root}/runtime-config-fixture"
  install -m 0644 -- \
    tests/fixtures/runtime-config/validator.json \
    tests/fixtures/runtime-config/jwks.json \
    "${staging_root}/runtime-config-fixture"

  chmod 0755 "${staging_root}"
  rm -rf -- "${integration_dir}"
  mv -- "${staging_root}" "${integration_dir}"
  SESSION_TEMP_ROOT=""
  printf '%s\n' "${integration_dir}"
}

usage() {
  printf '%s\n' \
    'usage: scripts/native-test <command>' \
    '' \
    'commands:' \
    '  prepare             install the pinned native toolchain' \
    '  policy              run shell and source policy gates' \
    '  dependencies        audit locked dependencies and licenses' \
    '  abi                 verify the official OAuth ABI inputs' \
    '  cargo-tests         run the Rust test feature matrix' \
    '  quality             run Rustfmt and Clippy' \
    '  production-artifact build and inspect the production module' \
    '  stage-integration   prepare native PostgreSQL test artifacts'
}

case "${1:-}" in
  help|--help|-h)
    usage
    ;;
  cargo-tests)
    require_github_actions
    run_cargo_tests
    ;;
  dependencies)
    require_github_actions
    run_dependencies
    ;;
  quality)
    require_github_actions
    run_quality
    ;;
  abi)
    require_github_actions
    run_abi
    ;;
  production-artifact)
    require_github_actions
    run_production_artifact
    ;;
  policy)
    run_policy
    ;;
  stage-integration)
    require_github_actions
    run_stage_integration
    ;;
  prepare)
    require_github_actions
    run_prepare
    ;;
  *)
    usage >&2
    exit 2
    ;;
esac
