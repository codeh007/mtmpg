#!/usr/bin/env bash
set -euo pipefail

umask 077
export LC_ALL=C

REPOSITORY_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
readonly REPOSITORY_ROOT
readonly OFFICIAL_IMAGE="postgres:18.4-bookworm@sha256:1961f96e6029a02c3812d7cb329a3b03a3ac2bb067058dec17b0f5596aca9296"
readonly DOCKER_BIN="${PGGOMTM_DOCKER_BIN:-docker}"
readonly SUDO_BIN="${PGGOMTM_SUDO_BIN:-sudo}"
readonly ARTIFACT_READINESS_BIN="${PGGOMTM_ARTIFACT_READINESS_BIN:-${REPOSITORY_ROOT}/scripts/artifact-readiness}"
readonly BUILD_METADATA_BIN="${PGGOMTM_BUILD_METADATA_BIN:-${REPOSITORY_ROOT}/scripts/build-metadata}"

SESSION_TEMP_ROOT=""
BASE_CONTAINER=""
CANDIDATE_CONTAINER=""
RUNTIME_CONTAINER=""

fail() {
  printf 'image-readiness: %s\n' "$1" >&2
  exit 2
}

require_github_actions() {
  test "${GITHUB_ACTIONS:-}" = "true" || \
    fail "recomputation is restricted to GitHub Actions; run the Native CI workflow"
}

cleanup() {
  if test -n "${RUNTIME_CONTAINER}"; then
    "${DOCKER_BIN}" rm --force "${RUNTIME_CONTAINER}" >/dev/null 2>&1 || true
  fi
  if test -n "${BASE_CONTAINER}"; then
    "${DOCKER_BIN}" rm --force "${BASE_CONTAINER}" >/dev/null 2>&1 || true
  fi
  if test -n "${CANDIDATE_CONTAINER}"; then
    "${DOCKER_BIN}" rm --force "${CANDIDATE_CONTAINER}" >/dev/null 2>&1 || true
  fi
  if test -n "${SESSION_TEMP_ROOT}"; then
    "${SUDO_BIN}" rm -rf -- "${SESSION_TEMP_ROOT}" >/dev/null 2>&1 || \
      rm -rf -- "${SESSION_TEMP_ROOT}" >/dev/null 2>&1 || true
  fi
}

trap cleanup EXIT INT TERM

require_tool() {
  command -v "$1" >/dev/null || fail "required tool is unavailable: $1"
}

validate_source_revision() {
  local source_revision="$1"
  [[ "${source_revision}" =~ ^[0-9a-f]{40}$ ]] || \
    fail "source revision must be a full lowercase Git commit"
}

assert_no_fixed_string() {
  local pattern="$1"
  local file_path="$2"
  local reason="$3"
  local status

  set +e
  grep --quiet --fixed-strings -- "${pattern}" "${file_path}"
  status=$?
  set -e
  case "${status}" in
    0) fail "${reason}" ;;
    1) ;;
    *) fail "negative image scan could not read ${file_path}" ;;
  esac
}

verify_image_config() {
  local base_inspect="$1"
  local candidate_inspect="$2"

  jq --exit-status \
    --slurpfile base "${base_inspect}" \
    --slurpfile candidate "${candidate_inspect}" '
      def runtime_contract:
        {
          entrypoint: .Config.Entrypoint,
          command: .Config.Cmd,
          volumes: .Config.Volumes,
          stop_signal: .Config.StopSignal,
          user: .Config.User,
          working_directory: .Config.WorkingDir,
          exposed_ports: .Config.ExposedPorts,
          environment: .Config.Env,
          healthcheck: .Config.Healthcheck,
          shell: .Config.Shell
        };
      ($base[0][0]) as $official
      | ($candidate[0][0]) as $image
      | ($official | runtime_contract) == ($image | runtime_contract)
    ' >/dev/null || fail "candidate changed the official runtime config"

  jq --exit-status \
    --slurpfile base "${base_inspect}" \
    --slurpfile candidate "${candidate_inspect}" '
      ($base[0][0]) as $official
      | ($candidate[0][0]) as $image
      | ($official.RootFS.Layers) as $base_layers
      | ($image.RootFS.Layers) as $candidate_layers
      | $official.Architecture == $image.Architecture
        and $official.Os == $image.Os
        and $official.Variant == $image.Variant
        and $official.OsVersion == $image.OsVersion
        and $official.RootFS.Type == $image.RootFS.Type
        and ($candidate_layers | length) == (($base_layers | length) + 3)
        and $candidate_layers[0:($base_layers | length)] == $base_layers
    ' >/dev/null || fail "candidate does not derive from the approved base layers"
}

export_container_root() {
  local container_id="$1"
  local archive="$2"
  local root="$3"

  "${DOCKER_BIN}" export --output "${archive}" "${container_id}"
  install -d -m 0755 -- "${root}"
  "${SUDO_BIN}" tar \
    --extract \
    --file="${archive}" \
    --directory="${root}" \
    --same-owner \
    --same-permissions
}

snapshot_root() {
  local root="$1"
  local inventory="$2"

  "${SUDO_BIN}" "${ARTIFACT_READINESS_BIN}" snapshot-filesystem \
    "${root}" \
    "${inventory}"
  "${SUDO_BIN}" chown "$(id -u):$(id -g)" "${inventory}"
  chmod 0644 "${inventory}"
}

verify_candidate_contents() {
  local candidate_root="$1"
  local source_revision="$2"
  local module_file="${candidate_root}/usr/lib/postgresql/18/lib/pggomtm.so"
  local license_file="${candidate_root}/usr/share/doc/pggomtm/LICENSE"
  local manifest_file="${candidate_root}/usr/share/doc/pggomtm/build-manifest.json"

  "${ARTIFACT_READINESS_BIN}" verify-elf "${module_file}"
  "${BUILD_METADATA_BIN}" verify-image \
    "${manifest_file}" \
    "${module_file}" \
    "${license_file}" \
    "${source_revision}"

  local module_strings="${SESSION_TEMP_ROOT}/module-strings"
  strings --all "${module_file}" >"${module_strings}"
  local forbidden
  for forbidden in \
    '"features":["pg18",' \
    'pggomtm_abi_gate' \
    'pggomtm_abi_runtime_probe' \
    'pggomtm_config_gate' \
    'pggomtm_identity_gate' \
    'pggomtm_pgx_gate' \
    'oauth-ordinary.jwt' \
    'candidate.example.test' \
    'synthetic-private-key' \
    'synthetic artifact' \
    'BEGIN PRIVATE KEY' \
    'BEGIN RSA PRIVATE KEY' \
    'BEGIN EC PRIVATE KEY'; do
    assert_no_fixed_string \
      "${forbidden}" \
      "${module_strings}" \
      "production module contains a gate, fixture, or credential marker: ${forbidden}"
  done
}

verify_runtime_files() {
  local image="$1"

  "${DOCKER_BIN}" run \
    --rm \
    --platform linux/amd64 \
    --entrypoint /tmp/pggomtm-artifact-readiness \
    --volume "${ARTIFACT_READINESS_BIN}:/tmp/pggomtm-artifact-readiness:ro" \
    "${image}" \
    verify-runtime /
}

verify_official_startup() {
  local image="$1"
  local runtime_name="pggomtm-image-readiness-${GITHUB_RUN_ID:-local}-$$"

  RUNTIME_CONTAINER="${runtime_name}"
  "${DOCKER_BIN}" run \
    --detach \
    --rm \
    --name "${RUNTIME_CONTAINER}" \
    --platform linux/amd64 \
    --env POSTGRES_HOST_AUTH_METHOD=trust \
    --tmpfs /var/lib/postgresql:rw,nosuid,nodev,size=512m \
    "${image}" \
    -c oauth_validator_libraries=pggomtm >/dev/null

  local ready=0
  local _
  for _ in $(seq 1 60); do
    if "${DOCKER_BIN}" exec "${RUNTIME_CONTAINER}" \
      pg_isready --username=postgres --dbname=postgres >/dev/null 2>&1; then
      ready=1
      break
    fi
    sleep 1
  done
  if test "${ready}" -ne 1; then
    "${DOCKER_BIN}" logs "${RUNTIME_CONTAINER}" >&2 || true
    fail "official entrypoint did not initialize PostgreSQL with the production module"
  fi

  test "$(
    "${DOCKER_BIN}" exec "${RUNTIME_CONTAINER}" \
      psql \
      --username=postgres \
      --dbname=postgres \
      --tuples-only \
      --no-align \
      --command='SHOW oauth_validator_libraries'
  )" = "pggomtm" || fail "PostgreSQL did not retain the production module setting"
  test "$(
    "${DOCKER_BIN}" exec "${RUNTIME_CONTAINER}" postgres --version
  )" = "postgres (PostgreSQL) 18.4 (Debian 18.4-1.pgdg12+1)" || \
    fail "running container does not identify the approved PostgreSQL 18.4 build"

  "${DOCKER_BIN}" stop --time 10 "${RUNTIME_CONTAINER}" >/dev/null
  RUNTIME_CONTAINER=""
}

verify_image() {
  test "$#" -eq 2 || fail "verify requires image and source revision"
  local image="$1"
  local source_revision="$2"

  test -n "${image}" && [[ "${image}" != *[[:space:]]* ]] || \
    fail "candidate image identity is invalid"
  validate_source_revision "${source_revision}"
  require_tool "${DOCKER_BIN}"
  require_tool "${SUDO_BIN}"
  require_tool jq
  require_tool strings
  test -x "${ARTIFACT_READINESS_BIN}" || fail "artifact-readiness is unavailable"
  test -x "${BUILD_METADATA_BIN}" || fail "build-metadata is unavailable"

  SESSION_TEMP_ROOT="$(mktemp --directory)"
  local base_inspect="${SESSION_TEMP_ROOT}/base-inspect.json"
  local candidate_inspect="${SESSION_TEMP_ROOT}/candidate-inspect.json"
  local base_archive="${SESSION_TEMP_ROOT}/base.tar"
  local candidate_archive="${SESSION_TEMP_ROOT}/candidate.tar"
  local base_root="${SESSION_TEMP_ROOT}/base-root"
  local candidate_root="${SESSION_TEMP_ROOT}/candidate-root"
  local base_inventory="${SESSION_TEMP_ROOT}/base.tsv"
  local candidate_inventory="${SESSION_TEMP_ROOT}/candidate.tsv"

  "${DOCKER_BIN}" pull "${OFFICIAL_IMAGE}" >/dev/null
  "${DOCKER_BIN}" image inspect "${OFFICIAL_IMAGE}" >"${base_inspect}"
  "${DOCKER_BIN}" image inspect "${image}" >"${candidate_inspect}"
  verify_image_config "${base_inspect}" "${candidate_inspect}"

  BASE_CONTAINER="$(
    "${DOCKER_BIN}" create --platform linux/amd64 "${OFFICIAL_IMAGE}"
  )"
  CANDIDATE_CONTAINER="$(
    "${DOCKER_BIN}" create --platform linux/amd64 "${image}"
  )"
  export_container_root "${BASE_CONTAINER}" "${base_archive}" "${base_root}"
  export_container_root \
    "${CANDIDATE_CONTAINER}" \
    "${candidate_archive}" \
    "${candidate_root}"
  snapshot_root "${base_root}" "${base_inventory}"
  snapshot_root "${candidate_root}" "${candidate_inventory}"
  "${ARTIFACT_READINESS_BIN}" verify-filesystem \
    "${base_inventory}" \
    "${candidate_inventory}"
  verify_candidate_contents "${candidate_root}" "${source_revision}"
  verify_runtime_files "${image}"
  verify_official_startup "${image}"

  cleanup
  SESSION_TEMP_ROOT=""
  printf 'final PostgreSQL image readiness passed: %s\n' "${image}"
}

usage() {
  printf '%s\n' \
    'usage: scripts/image-readiness verify IMAGE SOURCE_REVISION' \
    '' \
    "official base: ${OFFICIAL_IMAGE}"
}

case "${1:-}" in
  help|--help|-h)
    usage
    ;;
  verify)
    require_github_actions
    shift
    verify_image "$@"
    ;;
  *)
    usage >&2
    exit 2
    ;;
esac
