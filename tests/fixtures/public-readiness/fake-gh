#!/usr/bin/env bash
set -euo pipefail

if [[ -n "${FAKE_GH_CALL_LOG:-}" ]]; then
  printf '%s\n' "$*" >>"${FAKE_GH_CALL_LOG}"
fi

case "${1:-}" in
  repo)
    test "${2:-}" = "clone"
    test -n "${FAKE_GH_REPOSITORY:-}"
    test "${5:-}" = "--"
    test "${6:-}" = "--mirror"
    git clone --quiet --mirror "${FAKE_GH_REPOSITORY}" "${4}"
    ;;
  api)
    endpoint="${2:-}"
    shift 2

    response=""
    case "${endpoint}" in
      repos/*/actions/runs\?per_page=100)
        response='{"workflow_runs":[{"id":101}]}'
        ;;
      repos/*/actions/artifacts\?per_page=100)
        response='{"artifacts":[{"id":201,"expired":false}]}'
        ;;
      repos/*/actions/caches\?per_page=100)
        response='{"total_count":0,"actions_caches":[]}'
        ;;
      repos/*/issues\?state=all\&per_page=100)
        response='[{"number":1,"title":"clean issue","body":"clean"},{"number":2,"title":"clean pull","body":"clean","pull_request":{}}]'
        ;;
      repos/*/issues/1/comments\?per_page=100 | repos/*/issues/2/comments\?per_page=100)
        response='[{"body":"clean conversation comment"}]'
        ;;
      repos/*/pulls\?state=all\&per_page=100)
        response='[{"number":2,"title":"clean pull","body":"clean"}]'
        ;;
      repos/*/pulls/2/comments\?per_page=100)
        response='[{"body":"clean review comment"}]'
        ;;
      repos/*/pulls/2/reviews\?per_page=100)
        response='[{"body":"clean review"}]'
        ;;
      repos/*/pulls/2/files\?per_page=100)
        response='[{"filename":"clean.txt","patch":"clean"}]'
        ;;
      repos/*/pulls/2)
        response='{"number":2,"title":"clean pull","body":"clean"}'
        ;;
      repos/*/releases\?per_page=100)
        response='[{"id":301,"name":"clean release","assets":[{"id":302}]}]'
        ;;
      users/*/packages\?package_type=container\&per_page=100)
        response='[{"name":"other-package","repository":{"name":"mtmpg"}}]'
        ;;
      repos/*/actions/runs/101/logs | \
      repos/*/actions/artifacts/201/zip | \
      repos/*/releases/assets/302)
        response='clean downloaded surface'
        ;;
      *)
        printf 'fake-gh: unexpected endpoint\n' >&2
        exit 1
        ;;
    esac

    jq_filter=""
    while [[ "$#" -gt 0 ]]; do
      case "$1" in
        --jq)
          jq_filter="${2:-}"
          shift 2
          ;;
        --paginate)
          shift
          ;;
        -H | --header)
          shift 2
          ;;
        *)
          printf 'fake-gh: unexpected api argument\n' >&2
          exit 1
          ;;
      esac
    done

    if [[ -n "${jq_filter}" ]]; then
      printf '%s\n' "${response}" | jq --raw-output "${jq_filter}"
    else
      printf '%s\n' "${response}"
    fi
    ;;
  *)
    printf 'fake-gh: unexpected command\n' >&2
    exit 1
    ;;
esac
